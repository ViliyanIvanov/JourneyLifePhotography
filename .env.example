# ============================================================================
# Image URLs Configuration - Optimized Dual-Source Strategy
# ============================================================================
#
# Thumbnails (7.9 MB): Always served from frontend /public/JourneyLifePhotos/*_thumb.jpg
#   - Used for: Grid view, album covers, instant loading
#   - No configuration needed - hardcoded to /JourneyLifePhotos
#
# Full Images (273 MB): Served from backend or CDN
#   - Used for: Lightbox/modal view only (on-demand)
#   - Configured via NEXT_PUBLIC_FULL_IMAGE_BASE_URL below
# ============================================================================

# Full-size images location
# Development: Use local backend
NEXT_PUBLIC_FULL_IMAGE_BASE_URL=http://localhost:5000/static/photos

# Production options:
# Option 1: Backend API
# NEXT_PUBLIC_FULL_IMAGE_BASE_URL=https://api.journeylifephotography.com/static/photos
#
# Option 2: CDN (Cloudflare, CloudFront, etc.)
# NEXT_PUBLIC_FULL_IMAGE_BASE_URL=https://cdn.journeylifephotography.com/photos
#
# Option 3: S3 Direct
# NEXT_PUBLIC_FULL_IMAGE_BASE_URL=https://journey-life-photos.s3.amazonaws.com

# ============================================================================
# API Configuration
# ============================================================================

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# ============================================================================
# Authentication
# ============================================================================

# Add any other environment variables needed for your app
